# AssistService 로컬 환경변수 템플릿
# 사용법: cp .env.example .env  후 실제 값으로 채운다 (.env 는 커밋 금지)
# spring-dotenv 가 이 폴더의 .env 를 자동 로드한다.

# 로컬 MySQL
DB_URL=jdbc:mysql://localhost:3306/haru_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=여기에_로컬_MySQL_비밀번호

# 외부 API 키 (로컬 미사용 시 빈 값으로 두어도 기동됨)
SMS_API_KEY=
SMS_API_SECRET=
SMS_API_URL=
NAVER_CLOUD_CHATBOT_SECRET_KEY=
NAVER_CLOUD_CHATBOT_API_URL=
NAVER_CLOUD_OCR_SECRET_KEY=
NAVER_CLOUD_OCR_API_URL=
KAKAO_REST_API_KEY=

# --- prod/실연동 시에만 설정 (빈 값 금지: 쓸 때만 주석 해제) ---
# 게이트웨이(=FastAPI AI 챗봇 진입점) 주소. 미설정 시 http://localhost:8080
# GATEWAY_BASE_URL=http://localhost:8080
# 번역 API(MyMemory) 자격증명 — 비어 있어도 저용량은 동작
# TRANSLATE_API_KEY=
# TRANSLATE_API_EMAIL=
