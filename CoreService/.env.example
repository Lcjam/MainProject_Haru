# CoreService 로컬 환경변수 템플릿
# 사용법: cp .env.example .env  후 실제 값으로 채운다 (.env 는 커밋 금지)
# spring-dotenv 가 이 폴더의 .env 를 자동 로드한다.

# 로컬 MySQL
DB_URL=jdbc:mysql://localhost:3306/haru_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=여기에_로컬_MySQL_비밀번호

# --- 아래는 prod/실연동 시에만 설정. 로컬은 코드 기본값으로 동작 ---
# (주의) .env 에 빈 값으로 두면 ${VAR:default} 의 기본값이 적용되지 않는다.
#        쓸 때만 주석을 풀고 값을 채울 것. 안 쓰면 주석 유지.

# JWT 시크릿 — GateWay 와 반드시 동일한 값이어야 함
# JWT_SECRET=
# JWT_EXPIRATION=86400000

# 소셜 로그인 후 프론트 리다이렉트 URL
# OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/redirect

# OAuth2 클라이언트 자격증명 (소셜 로그인 실연동 시)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
